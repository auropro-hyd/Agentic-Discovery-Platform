# ── OS / editor noise ─────────────────────────────────────────────
.DS_Store
*.swp

# ── secrets (never commit) ────────────────────────────────────────
.env
v1/.env

# ── Claude / tooling local state ──────────────────────────────────
.claude/

# ── Python runtime ────────────────────────────────────────────────
__pycache__/
*.pyc
.pytest_cache/
v1/.venv/

# ── v1 runtime cache (regenerated; noisy) ─────────────────────────
v1/.cache/
v1/.cache.tmp/

# ── coverage artifacts (regenerated) ──────────────────────────────
.coverage
v1/.coverage
htmlcov/
v1/htmlcov/

# NOTE: out/, golden/, shared_context/, and the input documents ARE committed (by request) as a
# reference/handoff bundle. They contain the engagement org name in raw/internal layers — this repo
# is treated as private reference. Only secrets (.env), the LLM response cache, the venv, and OS
# noise are excluded.

# ── spec-kit local tooling + specs (not committed by request) ─────
.specify/
specs/
CLAUDE.md

# ── framework spike (LangGraph evaluation; NOT product code) ──────
# Recorded the plain-code-vs-LangGraph decision in specs/003; the spike files exercised the
# comparison and are kept local only — they are not part of the shipped engine.
v1/spike/
