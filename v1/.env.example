# Copy this file to  v1/.env  and fill in. run.py auto-loads it.
# You can set BOTH providers and switch per run with:  python run.py --domain o2c --provider azure

# ============================================================
# Default provider when --provider is not passed
# ============================================================
DISCOVERY_PROVIDER=anthropic

# ============================================================
# Anthropic (Claude / Opus — what the prototype is tuned for)
#   Get a key at console.anthropic.com -> API Keys
# ============================================================
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8         # optional; this is the default

# ============================================================
# Azure OpenAI (GPT-4o — for the AuroPro Azure-tenant story)
#   All 4 values come from the Azure Portal:
#   - ENDPOINT + API_KEY:  resource -> "Keys and Endpoint"
#   - DEPLOYMENT:          the deployment NAME you created (NOT the model name "gpt-4o")
#   - API_VERSION:         a current value, e.g. 2024-10-21
# ============================================================
# AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>
# AZURE_OPENAI_API_VERSION=2024-10-21

# ============================================================
# Force cache-only / offline (the --golden flag sets this automatically)
# ============================================================
# DISCOVERY_OFFLINE=1
