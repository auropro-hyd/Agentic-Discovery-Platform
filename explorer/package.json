{
  "name": "discovery-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive client-facing explorer for the AuroPro discovery report suite (the SPA companion to the static print suite).",
  "scripts": {
    "sync:data": "node scripts/sync-data.mjs",
    "predev": "node scripts/sync-data.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-data.mjs && node scripts/check-tokens.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0"
  }
}
